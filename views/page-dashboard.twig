{% extends "base.twig" %}
{% block content %}

<section id="user-dashboard" class="bg-black py-20">
    <div class="container mx-auto px-4">
        
        <div id="profile-news" class="flex flex-col lg:flex-row gap-y-8 lg:gap-y-0 justify-between">
            <div id="user-profile" class="flex flex-col w-full lg:w-3/12">
                <div class="flex flex-col flex-grow p-4 h-full">
                    <p class="text-sm font-medium text-pale-blue uppercase tracking-widest">Profile</p>
                    <div class="w-14 h-14 rounded-full flex items-center justify-center text-lg font-medium bg-[#1a3a5c] text-pale-blue my-4">
                        {% set initials = user.first_name|first|upper ~ user.last_name|first|upper %}
                        {{ initials }}
                    </div>
                    <p class="text-sm text-gray">Hello,</p>
                    <p class="text-xl font-semibold">{{user.display_name}}</p>
                    <div id="company-info" class="pt-5 flex flex-col flex-grow h-full">
            
                        {% set company = user.meta('company') %}
                        {% if userRole == 't1' %}
                        {% set userRole = '55%' %}
                        {% elseif userRole == 't2' %}
                        {% set userRole = '52.5%' %}
                        {% elseif userRole == 't3' %}
                        {% set userRole = '50%' %}
                        {% elseif userRole == '57_5' %}
                        {% set userRole = '57.5%' %}
                        {% elseif userRole == 'tier_57' %}
                        {% set userRole = '57%' %}
                        {% elseif userRole == 'sales' %}
                        {% set userRole = 'Sales Team' %}
                        {% elseif userRole == 'administrator' %}
                        {% set userRole = 'Administrator' %}
                        {% else %}
                        {% set userRole = 'None' %}
                        {% endif %}

                        {% set priceListUrl = null %}
                        {% if userRole == '55%' %}
                            {% set priceListUrl = '/docs/pricing/2026/june/GWS_PRICE_LIST_55_JUNE_26.xlsx' %}
                        {% elseif userRole == '52.5%' %}
                            {% set priceListUrl = '/docs/pricing/2026/june/GWS_PRICE_LIST_52_5_JUNE_26.xlsx' %}
                        {% elseif userRole == '50%' %}
                            {% set priceListUrl = '/docs/pricing/2026/june/GWS_PRICE_LIST_50_JUNE_26.xlsx' %}
                        {% elseif userRole == '57%' %}
                            {% set priceListUrl = '/docs/pricing/2026/june/GWS_PRICE_LIST_57_JUNE_26.xlsx' %}
                        {% elseif userRole == '57.5%' %}
                            {% set priceListUrl = '/docs/pricing/2026/june/GWS_PRICE_LIST_57_5_JUNE_26.xlsx' %}
                        {% endif %}

            
                        {% if userRole == '55%' or userRole == '52.5%' or userRole == '50%' or userRole == '57%' or userRole == '57.5%' %}
                            <div class="flex flex-col gap-y-3">
                                <p class="w-full text-sm"><span class="text-gray font-medium">Company</span><span class="float-right font-medium">{{company}}</span></p>
                                <p class="w-full text-sm"><span class="text-gray font-medium">Account type</span><span class="float-right font-medium">Distributor</span></p>
                            </div>
                            <hr class="text-gray my-4">
                            <div class="flex flex-col flex-grow gap-y-3">
                                <p class="w-full text-sm"><span class="text-gray font-medium">Your discount</span><span class="float-right font-medium">{{userRole}} off list</span></p>
                                <div class="flex flex-col flex-grow">
                                    <p class="w-full text-sm"><span class="text-gray font-medium">Price list effective</span><span class="float-right font-medium">06/01/2026</span></p>
                                    <div class="mt-auto"><button class="border border-gray rounded p-2 mt-3 w-full hover:bg-[#a7a8a940] hover:border-[#a7a8a940]"><a href="{{priceListUrl}}" class="text-white text-sm">Download your price list<i class="fa-solid fa-download ms-4"></i></a></button></div>
                                </div>
                            </div>
                        {% else %}
                            <div class="flex flex-col gap-y-3">
                                <p class="w-full text-sm"><span class="text-gray font-medium">Company</span><span class="float-right font-medium">{{company}}</span></p>
                                <p class="w-full text-sm"><span class="text-gray font-medium">Account type</span><span class="float-right font-medium">Sales Team</span></p>
                            </div>
                            <hr class="text-gray my-4">
                            <div class="flex flex-col flex-grow">
                                <p class="w-full text-sm"><span class="text-gray font-medium">Price list effective</span><span class="float-right font-medium">06/01/2026</span></p>
                                <div class="mt-auto">
                                    <button class="border border-gray rounded p-2 mt-3 w-full hover:bg-[#a7a8a940] hover:border-[#a7a8a940] mt-auto"><a href="#quick-links" class="text-white text-sm">View price lists<i class="fa-solid fa-download ms-4"></i></a></button>
                                </div>
                            </div>
                        {% endif %}

                    </div>
                </div>
            </div>
            <div id="dashboard-news" class="flex flex-col w-full lg:w-8/12 min-w-0">
                <div class="flex flex-col flex-grow p-4 h-full">
                    <p class="text-sm font-medium text-pale-blue uppercase tracking-widest">News</p>
                    <div class="dashboard-swiper swiper mt-4 overflow-hidden w-full h-full">
                        <div class="swiper-wrapper">
                            {% for post in dashboard_posts %}
                                <div class="me-4 min-h-[250px] card swiper-slide relative group" style="background-image:url('{{post.thumbnail()}}'); background-color:rgba(0,0,0,.75); background-blend-mode: overlay; background-position: center; background-size: cover;">
                                    <a href="{{post.link}}" class="absolute h-full w-full"></a>
                                    <div class="card-conten p-5 h-full w-full flex flex-col justify-between">
                                    
                                        
                                        <div>
                                            <p class="text-xs uppercase font-semibold border border-white rounded-full inline-flex px-2 py-.5">{{ post.category() }}</p> 
                                        </div>
                                        <div>
                                            <h3 class="text-xl font-semibold text-pale-blue mb-4">{{ post.title }}</h3>
                                            <button><a href="{{post.link}}">Read More<i class="fa-solid fa-arrow-right-long mx-3 group-hover:translate-x-2"></i></a></button>
                                        </div>
                                    </div>
                                </div>

                            {% endfor %}
                        </div>
                    </div>
                    <div class="flex justify-between items-center my-4">
                        <div class="swiper-controls flex gap-x-6">
                                <i class="text-4xl font-bold text-pale-blue fa-solid fa-arrow-left-long prevEl"></i>
                                <i class="text-4xl font-bold text-pale-blue fa-solid fa-arrow-right-long nextEl"></i>
                        </div>
                        <button><a class="btn dark-blue" href="/gws-blog">View More News</a></button>
                    </div>
                </div>
            </div>
        </div>


        <div class="flex flex-col lg:flex-row gap-y-6 justify-between mt-8 gap-x-4">
            <div id="rapid-quote-dash" class="w-full lg:w-6/12 box-shadow h-52 flex flex-col justify-end ps-8 pb-8">
                <h3 class="text-4xl font-black uppercase">Rapid Quote</h3>
                <div><button class="btn dark-blue"><a href="/cart">Start Your Quote</a></button></div>
            </div>
            <div id="tool-filter-dash" class="w-full lg:w-6/12 box-shadow h-52 flex flex-col justify-end ps-8 pb-8">
                <h3 class="text-4xl font-black uppercase">Tool Filter</h3>
                <div id="tool-filter-start" class="fit-content">
                        <div class="inline-flex items-center gap-3">
                            <select id="tool-filter-select" class="bg-gray-50 border border-gray-300 text-black text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                                <option selected>What type of tool do you need?</option>
                                <option value="/products/milling">Milling</option>
                                <option value="/products/holemaking">Holemaking</option>
                                <option value="/products/specialty">Specialty</option>
                                <option value="/products/threading">Threading</option>
                                <option value="/products/inserts">Inserts</option>
                            </select>  
                            <!-- Loading spinner -->
                            <div id="tool-filter-spinner" class="hidden">
                                <svg class="animate-spin h-6 w-6 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                            </div>
                        </div>
