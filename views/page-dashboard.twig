<script>
    const swiper = new Swiper('.dashboard-swiper', {
        slidesPerView: 3,
        spaceBetween: 12,
        loop: true,
    
        pagination: {
            el: '.swiper-pagination',
            clickable: true,
        },
        navigation: {
            nextEl: ".nextEl",
            prevEl: ".prevEl",
        },
        breakpoints: {
            1300: {
                slidesPerView: 3,
            },
            768: {
                slidesPerView: 2,
            },
            0: {
                slidesPerView: 1,
            }
        }
    });
</script>
